# SkyFrame location + identity config
# Copy this file to .env and fill in your values.
#
# To find your NWS metadata, run:
#   curl https://api.weather.gov/points/{YOUR_LAT},{YOUR_LON}
# and pull the values from the response.

SKYFRAME_LAT=
SKYFRAME_LON=
SKYFRAME_EMAIL=your-email@example.com

# NWS point metadata (from the /points response above)
SKYFRAME_FORECAST_OFFICE=
SKYFRAME_GRID_X=
SKYFRAME_GRID_Y=
SKYFRAME_TIMEZONE=
SKYFRAME_FORECAST_ZONE=

# Observation stations (find via the /points response's observationStations URL)
SKYFRAME_STATION_PRIMARY=
SKYFRAME_STATION_FALLBACK=

# Display name shown in the TopBar (e.g., "CHICAGO 60614" or "PORTLAND 97201")
SKYFRAME_LOCATION_NAME=
